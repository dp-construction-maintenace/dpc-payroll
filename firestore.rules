rules_version = '2';

// These rules mean: only someone signed in with a Firebase Auth account
// you created (Firebase Console → Authentication → Users) can read or
// write any payroll data. Nobody else — including anonymous visitors to
// your GitHub Pages URL — can see or change anything.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
